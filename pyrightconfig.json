{
  "pythonVersion": "3.12",
  "pythonPlatform": "Darwin",
  "venvPath": ".",
  "venv": ".venv",
  "include": [
    "acorn-core/src",
    "acorn-core/tests",
    "acorn-events/src",
    "acorn-agent/src",
    "examples-plugin/src",
    "value-investment-plugin/vi_core/src",
    "value-investment-plugin/vi_core/tests",
    "value-investment-plugin/vi_fields_ifrs/src",
    "value-investment-plugin/vi_fields_extension/src",
    "value-investment-plugin/provider_tushare/src",
    "value-investment-plugin/calculators",
    "value-investment-plugin/calculators/tests",
    "value-investment-plugin/vi_calculators",
    "value-investment-plugin/vi_cli/src"
  ],
  "exclude": [
    "**/__pycache__",
    ".venv"
  ],
  "extraPaths": [
    ".venv/lib/python3.12/site-packages",
    "acorn-events/src",
    "value-investment-plugin/vi_core/src",
    "value-investment-plugin/vi_fields_ifrs/src",
    "value-investment-plugin/vi_fields_extension/src",
    "value-investment-plugin/provider_tushare/src",
    "value-investment-plugin/calculators",
    "value-investment-plugin/vi_calculators",
    "value-investment-plugin/tests"
  ],
  "executionEnvironments": [
    {
      "root": "."
    }
  ],
  "typeCheckingMode": "basic"
}
